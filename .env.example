# .env.example — copy to .env and fill in real values. .env is gitignored.
#
# Loaded two ways:
#   • Python entry points import load_env.py, which reads .env into os.environ
#     (already-exported shell variables win over the file).
#   • run_scheduled.sh sources .env directly for launchd runs, which start
#     with a bare environment.

# Anthropic API key — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-..."

# Gmail sender account. GMAIL_APP_PASSWORD is a 16-char app password
# (https://myaccount.google.com/apppasswords — 2-Step Verification required),
# NOT the normal login password.
GMAIL_ADDRESS="you@gmail.com"
GMAIL_APP_PASSWORD="abcd efgh ijkl mnop"

# Who receives the weekly brief / daily pulse — comma-separated.
RECIPIENTS="you@gmail.com,someone-else@example.com"

# Where pipeline-failure alerts go (owner only, not the full recipient list).
# Optional — defaults to GMAIL_ADDRESS if unset.
ALERT_RECIPIENT="you@gmail.com"
